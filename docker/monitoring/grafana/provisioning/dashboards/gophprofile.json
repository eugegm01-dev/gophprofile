  "liveNow": false,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 }, "unit": "reqps" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "title": "Request Rate (RPS)",
      "type": "timeseries",
      "targets": [{ "expr": "sum(rate(http_server_request_duration_seconds_count[1m]))", "legendFormat": "Total RPS" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 5 }] } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "title": "Error Rate (%)",
      "type": "gauge",
      "targets": [{ "expr": "sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m])) / sum(rate(http_server_request_duration_seconds_count[5m])) * 100" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "title": "Latency p95 (HTTP)",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "thresholds": { "steps": [{ "color": "green", "value": 0 }] } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "title": "Avatar Uploads (Business KPI)",
      "type": "stat",
      "targets": [{ "expr": "sum(increase(avatars_uploads_total{status=\"success\"}[5m]))", "legendFormat": "Uploads per 5m" }]
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "title": "Application Logs (Loki)",
      "type": "logs",
      "targets": [{ "expr": "{container=\"gophprofile-server\"}", "refId": "A" }]
    }
  ],
